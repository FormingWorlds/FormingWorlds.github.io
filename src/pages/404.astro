---
import Base from '../layouts/Base.astro';
---
<Base title="Page not found" description="Sorry, the page you are looking for does not exist." titleBlock={false}>
  <div class="page-header error-page fullWidth">
    <div class="page-header-image" style="background-image: url('/assets/img/ill/404.svg')"></div>
    <div class="container">
      <div class="row">
        <div class="col-md-12 text-center">
          <h1 class="title">404</h1>
          <p class="lead">Page not found :(</p>
          <h4 class="description text-default">Ooooups! Looks like you got lost.</h4>
        </div>
      </div>
    </div>
  </div>
</Base>
