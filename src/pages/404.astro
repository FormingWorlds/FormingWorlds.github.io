---
import Base from '../layouts/Base.astro';
---
<Base title="Page not found" description="Sorry, the page you are looking for does not exist." titleBlock={false}>
  <div class="error-page">
    <img class="error-glyph only-dark" src="/assets/img/brand/glyph_phase_dark.png" alt="" aria-hidden="true" />
    <img class="error-glyph only-light" src="/assets/img/brand/glyph_phase_light.png" alt="" aria-hidden="true" />
    <h1 class="title">404</h1>
    <p class="error-lead">We could not find that page.</p>
    <p class="description">The address may be mistyped, or the page may have moved.</p>
  </div>

<style>
  .error-page {
    text-align: center;
    padding: 110px 0 60px;
  }
  .error-glyph {
    width: var(--pt-9);
    margin: 0 auto var(--pt-6);
  }
  .error-page .title {
    font-family: var(--pt-font-display);
    font-weight: 800;
    font-size: clamp(72px, 12vw, var(--pt-fs-120));
    letter-spacing: -0.025em;
    line-height: 1;
    margin: 0;
  }
  .error-page .error-lead {
    font-size: 19px;
    color: var(--pt-text-d2);
    margin: 18px 0 6px;
  }
  .error-page .description {
    font-family: var(--pt-font-mono);
    font-weight: 400;
    font-size: var(--pt-fs-13);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--pt-text-d2);
    margin: 0;
  }
</style>
</Base>
