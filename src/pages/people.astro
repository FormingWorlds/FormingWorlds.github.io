---
<Base
  title="Meet the team"
  subtitle='For enquiries please write an email to <a href="mailto:proteus_dev@formingworlds.space">proteus_dev@formingworlds.space</a>'
  description="The PROTEUS development team: researchers and software engineers building open-source tools for rocky planet evolution."
  image="/assets/img/og-default.jpg"
>
  <h2 class="team-heading">Current developers</h2>
  <div class="team-grid" id="current-developers-section">
    {currentDevelopers.map((person) => (
      <div class="person-card">
        <a href={person.url} target="_blank" rel="noopener noreferrer" class="person-photo">
          <img src={person.photo} alt={person.name} loading="lazy" style={person.objectPosition ? `object-position: ${person.objectPosition}` : undefined} />
        </a>
        <div class="person-body">
          <h3 class="person-name">{person.name}</h3>
          <p class="person-role">{person.role}</p>
          <ul class="person-topics">
            {person.topics.map((topic) => <li>{topic}</li>)}
          </ul>
        </div>
      </div>
    ))}
  </div>

  <h2 class="team-heading">Past contributors</h2>
  <div class="team-grid" id="past-contributors-section">
    {pastContributors.map((person) => (
      <div class="person-card">
        <a href={person.url} target="_blank" rel="noopener noreferrer" class="person-photo">
          <img src={person.photo} alt={person.name} loading="lazy" style={person.objectPosition ? `object-position: ${person.objectPosition}` : undefined} />
        </a>
        <div class="person-body">
          <h3 class="person-name">{person.name}</h3>
          <p class="person-role">{person.role}</p>
          <ul class="person-topics">
            {person.topics.map((topic) => <li>{topic}</li>)}
          </ul>
        </div>
      </div>
    ))}
  </div>

<style is:global>
  .team-heading {
    font-family: var(--pt-font-display);
    font-weight: 800;
    font-size: 28px;
    letter-spacing: -0.02em;
    margin: 56px 0 var(--pt-5);
  }
  .team-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(210px, 1fr));
    gap: 18px;
  }
  .person-card {
    background: var(--pt-basalt);
    border: 1px solid var(--pt-line-d);
    border-radius: var(--pt-r-2);
    overflow: hidden;
  }
  /* The photo is a link to the person's profile; the zoom-and-lift on hover or
     keyboard focus signals that it is clickable. */
  .person-photo { display: block; overflow: hidden; }
  .person-photo img {
    display: block;
    width: 100%;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    object-position: top;
    transition: transform 0.45s ease, filter 0.3s ease;
  }
  .person-photo:hover img,
  .person-photo:focus-visible img {
    transform: scale(1.05);
    filter: brightness(1.06);
  }
  @media (prefers-reduced-motion: reduce) {
    .person-photo img { transition: filter 0.3s ease; }
    .person-photo:hover img,
    .person-photo:focus-visible img { transform: none; }
  }
  .person-body { padding: 14px var(--pt-4) var(--pt-4); }
  .person-name {
    font-family: var(--pt-font-display);
    font-weight: 700;
    font-size: var(--pt-fs-16);
    letter-spacing: -0.01em;
    color: var(--pt-text-d);
    margin: 0;
  }
  .person-role {
    font-family: var(--pt-font-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--pt-azure);
    margin: 6px 0 0;
    line-height: 1.5;
  }
  /* Research topics ride along in the markup but are not part of the card
     design. */
  .person-topics { display: none; }
</style>

<script is:inline>
document.addEventListener('DOMContentLoaded', function() {
  // Shuffle each team section so the display order varies per visit.
  function shuffleSection(containerId) {
    const container = document.getElementById(containerId);
    if (!container) return;
    const cards = Array.from(container.children);
    // Fisher-Yates shuffle
    for (let i = cards.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [cards[i], cards[j]] = [cards[j], cards[i]];
    }
    cards.forEach((card) => container.appendChild(card));
  }

  shuffleSection('current-developers-section');
  shuffleSection('past-contributors-section');
});
</script>
</Base>
