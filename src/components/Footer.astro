---
// Site footer: phase rule, brand lockup, navigation columns, contact address,
// and social buttons.
import { menuItems, contactEmail } from '../data/settings.js';
import Socials from './Socials.astro';

const navItems = menuItems.filter((item) => !item.submenuItems);
const year = new Date().getFullYear();
---
<div class="phase-rule"></div>
<footer class="site">
  <div class="wrap">
    <div class="foot-grid">
      <div class="foot-col">
        <a href="/" class="foot-lockup" aria-label="PROTEUS">
          <span class="word">PR<img class="only-dark" src="/assets/img/brand/glyph_phase_dark.png" alt="O" /><img class="only-light" src="/assets/img/brand/glyph_phase_light.png" alt="O" />TEUS</span>
          <span class="tag">framework</span>
        </a>
      </div>
      <div class="foot-col">
        <h6>Navigate</h6>
        {navItems.map((item) => <a href={item.url}>{item.title}</a>)}
      </div>
      <div class="foot-col">
        <h6>Documentation</h6>
        <a href="https://proteus-framework.org/PROTEUS/" target="_blank" rel="noopener noreferrer">PROTEUS docs</a>
        <a href="/modules">Module overview</a>
        <a href="https://github.com/FormingWorlds/PROTEUS" target="_blank" rel="noopener noreferrer">GitHub repository</a>
      </div>
      <div class="foot-col">
        <h6>Contact</h6>
        <a href={`mailto:${contactEmail}`}>{contactEmail}</a>
        <div style="margin-top: 14px;">
          <Socials />
        </div>
      </div>
    </div>
    <div class="foot-bottom">
      <span>&copy; 2023-{year} <a href="https://www.formingworlds.space" target="_blank" rel="noopener noreferrer">Forming Worlds Lab</a></span>
    </div>
  </div>
</footer>

<style>
  .foot-lockup .word { display: inline-flex; }
  .foot-bottom a { color: var(--pt-text-d2); }
  .foot-bottom a:hover { color: var(--pt-ice); }
</style>
