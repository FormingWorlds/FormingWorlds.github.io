---
import Base from '../layouts/Base.astro';
import Lockup from '../components/Lockup.astro';

// Homepage module overview: name, one-line brief, and the module's physical
// domain, which sets the swatch colour via the shared .dom-* classes in
// site.css.
const overviewModules = [
  { name: 'AGNI / JANUS', brief: 'Radiative-convective atmosphere models', domain: 'atmos' },
  { name: 'SPIDER / Aragog', brief: 'Magma ocean and mantle evolution', domain: 'interior' },
  { name: 'CALLIOPE / Atmodeller', brief: 'Volatile partitioning and outgassing', domain: 'outgassing' },
  { name: 'VULCAN', brief: 'Atmospheric photochemistry', domain: 'chem' },
  { name: 'ZEPHYRUS', brief: 'Hydrodynamic atmospheric escape', domain: 'chem' },
  { name: 'MORS', brief: 'Stellar evolution tracks', domain: 'stellar' },
  { name: 'LovePy / Obliqua', brief: 'Tidal dissipation and heating', domain: 'tidal' },
  { name: 'Zalmoxis', brief: 'Planetary interior structure', domain: 'interior' },
];

// A typo'd domain would render an invisible swatch; fail the build instead.
const knownDomains = ['interior', 'outgassing', 'tidal', 'chem', 'atmos', 'stellar'];
for (const m of overviewModules) {
  if (!knownDomains.includes(m.domain)) {
    throw new Error(`Unknown module domain "${m.domain}" for ${m.name}`);
  }
}
---
<Base
  title="Home"
  titleBlock={false}
  ogType="website"
  description="PROTEUS is an open-source framework for simulating the coupled interior-atmosphere evolution of rocky planets, from magma oceans to habitable worlds."
  image="/assets/img/og-default.jpg"
>
  <!-- The hero stays dark in both themes (tokens.css restores the dark text
       tokens under [data-theme="light"] .hero), so the lockup uses the dark
       glyph directly rather than the only-dark/only-light swap. -->
  <section class="hero fullbleed">
    <div class="wrap narrow hero-inner">
      <Lockup tag="h1" class="hero-lockup" ariaLabel="PROTEUS framework" />
      <p class="hero-tagline">Simulate the coupled interior-atmosphere evolution of rocky planets over deep time.</p>
      <p class="hero-subtitle">Named after the Greek god of sea change, PROTEUS is flexible and adaptable; it can foretell the future, but answers only to those who ask the right questions.</p>
      <div class="hero-actions">
        <a href="https://proteus-framework.org/PROTEUS/" class="btn btn-primary" target="_blank" rel="noopener noreferrer">Documentation</a>
        <a href="/demos" class="btn btn-ghost">See demos</a>
      </div>
    </div>
    <p class="hero-credit">Artwork &copy; Mark A. Garlick</p>
    <div class="hero-band" aria-hidden="true"></div>
  </section>

  <section class="home-overview">
    <p class="overview-lead">
      PROTEUS is an open-source framework that couples models of planetary interiors, atmospheres, chemistry, and orbital dynamics to simulate how rocky planets evolve from molten beginnings to potentially habitable worlds.
    </p>

    <h2 class="section-label">Modules</h2>
    <div class="overview-modules">
      {overviewModules.map((m) => (
        <a href="/modules" class="overview-module">
          <span class={`module-swatch dom-${m.domain}`}></span>
          <div>
            <strong>{m.name}</strong>
            <span class="module-brief">{m.brief}</span>
          </div>
        </a>
      ))}
    </div>
    <div class="overview-more">
      <a href="/modules" class="overview-link">Full module details</a>
    </div>
  </section>

<style is:global>
  /* ---------- hero ---------- */
  /* Planetary-system artwork behind a dark scrim that keeps the lockup and
     text legible; the token gradient sits underneath as the pre-load and
     fallback background. */
  .hero {
    position: relative;
    overflow: hidden;
    background:
      linear-gradient(rgba(5, 7, 11, 0.55), rgba(5, 7, 11, 0.3) 45%, rgba(5, 7, 11, 0.65)),
      url('/assets/img/illustrations/two_face_planet.jpg') center / cover no-repeat,
      var(--pt-grad-hero);
    border-bottom: 1px solid var(--pt-line-d);
  }
  .hero-inner {
    position: relative;
    z-index: 1;
    padding-top: 110px;
    padding-bottom: var(--pt-9);
  }
  .hero-credit {
    position: absolute;
    right: 14px;
    bottom: calc(var(--pt-2) + 10px);
    z-index: 1;
    margin: 0;
    font-family: var(--pt-font-mono);
    font-size: 10px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--pt-text-d2);
    opacity: 0.35;
    text-shadow: 0 1px 2px rgba(5, 7, 11, 0.6);
  }
  /* Hero variant of the brand lockup: the shared .brand-lockup rules carry
     the structure and glyph alignment; this scales it up for the banner. */
  .hero-lockup {
    --lockup-size: clamp(56px, 10vw, var(--pt-fs-120));
    --lockup-tag-size: clamp(10px, 1.6vw, var(--pt-fs-20));
    --lockup-tag-gap: 14px;
  }
  .hero-tagline {
    font-size: clamp(19px, 2.4vw, 26px);
    font-weight: 600;
    line-height: 1.45;
    color: var(--pt-text-d);
    max-width: 34ch;
    margin-top: 56px;
  }
  .hero-subtitle {
    font-size: 17px;
    line-height: 1.65;
    color: var(--pt-text-d2);
    max-width: 62ch;
    margin-top: 18px;
  }
  .hero-actions { display: flex; flex-wrap: wrap; gap: 14px; margin-top: 40px; }
  .hero-band {
    position: relative;
    z-index: 1;
    height: var(--pt-2);
    background: var(--pt-grad-phase);
  }

  /* ---------- overview ---------- */
  .home-overview { padding: 72px 0 0; }
  .overview-lead {
    font-size: 19px;
    line-height: 1.7;
    color: var(--pt-text-d2);
    max-width: 76ch;
  }
  .home-overview .section-label { margin-top: var(--pt-8); }
  .overview-modules {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 14px var(--pt-7);
  }
  /* Each entry links to the module details page; the hover surface signals
     that the rows are clickable. The selector outweighs the chrome's generic
     content-link underline rule. */
  .home-overview .overview-module {
    display: flex;
    align-items: flex-start;
    gap: 14px;
    padding: 6px 10px;
    margin: 0 -10px;
    border-radius: var(--pt-r-2);
    text-decoration: none;
  }
  .home-overview .overview-module:hover {
    background: var(--pt-basalt-2);
  }
  /* Swatch colour comes from the shared .dom-* classes in site.css. */
  .module-swatch {
    width: 22px;
    height: 14px;
    border-radius: 3px;
    flex-shrink: 0;
    margin-top: 5px;
  }
  .overview-module strong { color: var(--pt-text-d); font-size: var(--pt-fs-16); }
  .module-brief {
    display: block;
    color: var(--pt-text-d2);
    font-size: 14.5px;
    margin-top: 2px;
  }
  .overview-more { margin-top: 20px; text-align: right; }
  .overview-link {
    font-family: var(--pt-font-mono);
    font-size: var(--pt-fs-13);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  @media (max-width: 576px) {
    .overview-modules { grid-template-columns: 1fr; }
    .overview-lead { font-size: 17px; }
    .hero-actions .btn { width: 100%; justify-content: center; }
  }

</style>
</Base>
