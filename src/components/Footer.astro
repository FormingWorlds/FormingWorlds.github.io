---
// Site footer: navigation columns, contact address, and social buttons.
// Also carries the end-of-body scripts that drive the navbar and set content padding.
import { menuItems, footerLogos, contactEmail } from '../data/settings.js';
import Socials from './Socials.astro';

const navItems = menuItems.filter((item) => !item.submenuItems);
const year = new Date().getFullYear();
---
<footer class="footer mt-5 pt-5">
  <div class="container">
    <div class="row mb-4">
      <div class="col-lg-4 mb-4 mb-lg-0">
        <img src={footerLogos.light} alt="PROTEUS" style="max-height: 40px;" class="mb-3 footer-logo-light" loading="lazy">
        <img src={footerLogos.dark} alt="PROTEUS" style="max-height: 40px;" class="mb-3 footer-logo-dark" loading="lazy">
      </div>
      <div class="col-lg-2 col-md-4 col-6">
        <h6 class="text-uppercase font-weight-bold mb-3">Navigate</h6>
        <ul class="list-unstyled">
          {navItems.map((item) => (
            <li class="mb-2"><a href={item.url} class="text-muted">{item.title}</a></li>
          ))}
        </ul>
      </div>
      <div class="col-lg-3 col-md-4 col-6">
        <h6 class="text-uppercase font-weight-bold mb-3">Documentation</h6>
        <ul class="list-unstyled">
          <li class="mb-2"><a href="https://proteus-framework.org/PROTEUS/" class="text-muted" target="_blank" rel="noopener noreferrer">PROTEUS docs</a></li>
          <li class="mb-2"><a href="/modules" class="text-muted">Module overview</a></li>
          <li class="mb-2"><a href="https://github.com/FormingWorlds/PROTEUS" class="text-muted" target="_blank" rel="noopener noreferrer">GitHub repository</a></li>
        </ul>
      </div>
      <div class="col-lg-3 col-md-4">
        <h6 class="text-uppercase font-weight-bold mb-3">Contact</h6>
        <p class="text-muted mb-2">
          <a href={`mailto:${contactEmail}`} class="text-muted">{contactEmail}</a>
        </p>
        <div class="mt-3">
          <Socials />
        </div>
      </div>
    </div>
    <hr>
    <div class="row align-items-center py-3">
      <div class="col-md-6">
        <div class="copyright">
          <span class="text-muted">&copy; 2023-{year} <a href="https://www.formingworlds.space" target="_blank" rel="noopener noreferrer" class="text-muted">Forming Worlds Lab</a></span>
        </div>
      </div>
      <div class="col-md-6 text-md-right">
      </div>
    </div>
  </div>
</footer>

<!-- Navigation behaviour: mobile menu, dropdown submenus, theme toggle -->
<script is:inline>
  (function () {
    var LG = 992; // below this width the collapsed menu is active
    document.addEventListener('click', function (e) {
      var nav = document.getElementById('navbar-main');
      if (!nav) return;
      var collapse = document.getElementById('navbar_global');
      var mobile = window.innerWidth < LG;

      // Hamburger and close button: open or close the collapsed panel
      var toggler = e.target.closest('.navbar-toggler[data-target]');
      if (toggler && nav.contains(toggler)) {
        var target = document.querySelector(toggler.getAttribute('data-target'));
        if (target) target.classList.toggle('show');
        return;
      }

      // On mobile, tapping a dropdown toggle expands its submenu inline
      var dt = e.target.closest('[data-toggle="dropdown"]');
      if (mobile && dt && nav.contains(dt)) {
        e.preventDefault();
        var li = dt.closest('.nav-item.dropdown');
        if (li) {
          li.classList.toggle('show');
          var menu = li.querySelector('.dropdown-menu');
          if (menu) menu.classList.toggle('show');
        }
        return;
      }

      // On mobile, clicking outside an open menu closes it
      if (mobile && collapse && collapse.classList.contains('show') && !collapse.contains(e.target)) {
        collapse.classList.remove('show');
      }
    });

    // Escape closes the mobile menu
    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape') {
        var collapse = document.getElementById('navbar_global');
        if (collapse) collapse.classList.remove('show');
      }
    });
  })();
</script>

<script is:inline>
  document.addEventListener('DOMContentLoaded', function () {
    var nav = document.getElementById('navbar-main');
    if (nav) {
      var offset = nav.offsetHeight;
      var els = document.querySelectorAll('.contentWrapper');
      for (var i = 0; i < els.length; i++) {
        els[i].style.paddingTop = (offset * 2) + 'px';
      }
    }
  });
</script>
