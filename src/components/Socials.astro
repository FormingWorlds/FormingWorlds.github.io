---
// Social buttons, ported from _includes/socials.html.
// Each entry key (e.g. `github_url`) drives the button class, tooltip label,
// and Font Awesome icon exactly as the original Liquid did.
import { socialSettings } from '../data/settings.js';

const entries = Object.entries(socialSettings).filter(([, url]) => url !== '');

function capitalize(s) {
  return s.charAt(0).toUpperCase() + s.slice(1);
}

const buttons = entries.map(([key, url]) => {
  // {{ key | remove: '_url' | replace: '-', ' ' }}
  const name = key.replace('_url', '').replace(/-/g, ' ');
  // {{ key | remove: '_url' | replace: '-', ' ' | capitalize }}
  const label = capitalize(name);
  // {{ key | replace: 'facebook', 'facebook-f' | remove: '_url' }}
  const icon = key.replace('facebook', 'facebook-f').replace('_url', '');
  return { url, className: name, label, icon };
});
---
{buttons.map((b) => (
  <button
    onclick={`window.open('${b.url}', '_blank');`}
    rel="nofollow"
    class={`btn btn-icon-only btn-${b.className} rounded-circle`}
    data-toggle="tooltip"
    data-original-title={b.label}
  >
    <span class="btn-inner--icon">
      <i class={`fab fa-${b.icon}`} aria-hidden="true"></i>
    </span>
  </button>
))}
