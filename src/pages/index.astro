---
import Base from '../layouts/Base.astro';

// Homepage module overview: name, one-line brief, and the module's physical
// domain, which sets the swatch colour (tokens --pt-dom-*).
const overviewModules = [
  { name: 'AGNI / JANUS', brief: 'Radiative-convective atmosphere models', domain: 'atmos' },
  { name: 'SPIDER / Aragog', brief: 'Magma ocean and mantle evolution', domain: 'interior' },
  { name: 'CALLIOPE / Atmodeller', brief: 'Volatile partitioning and outgassing', domain: 'outgassing' },
  { name: 'VULCAN', brief: 'Atmospheric photochemistry', domain: 'chem' },
  { name: 'ZEPHYRUS', brief: 'Hydrodynamic atmospheric escape', domain: 'chem' },
  { name: 'MORS', brief: 'Stellar evolution tracks', domain: 'stellar' },
  { name: 'LovePy / Obliqua', brief: 'Tidal dissipation and heating', domain: 'tidal' },
  { name: 'Zalmoxis', brief: 'Planetary interior structure', domain: 'interior' },
];
---
<Base
  title="Home"
  titleBlock={false}
  ogType="website"
  description="PROTEUS is an open-source framework for simulating the coupled interior-atmosphere evolution of rocky planets, from magma oceans to habitable worlds."
  image="/assets/img/og-default.jpg"
>
  <!-- The hero stays dark in both themes (tokens.css restores the dark text
       tokens under [data-theme="light"] .hero), so it uses the dark glyph
       directly rather than the only-dark/only-light swap. -->
  <section class="hero fullbleed">
    <img class="hero-glyph" src="/assets/img/brand/glyph_phase.svg" alt="" aria-hidden="true" />
    <div class="wrap narrow hero-inner">
      <div class="hero-lockup" aria-label="PROTEUS framework">
        <span class="word">PR<img src="/assets/img/brand/glyph_phase_dark.png" alt="O" />TEUS</span>
        <span class="tag">framework</span>
      </div>
      <p class="hero-tagline">Simulate the coupled interior-atmosphere evolution of rocky planets over deep time.</p>
      <p class="hero-subtitle">Named after the Greek god of sea change, PROTEUS is flexible and adaptable; it can foretell the future, but answers only to those who ask the right questions.</p>
      <div class="hero-actions">
        <a href="https://proteus-framework.org/PROTEUS/" class="btn btn-primary" target="_blank" rel="noopener noreferrer">Documentation</a>
        <a href="/demos" class="btn btn-ghost">See demos</a>
      </div>
    </div>
    <div class="hero-band" aria-hidden="true"></div>
  </section>

  <section class="home-overview">
    <p class="overview-lead">
      PROTEUS is an open-source framework that couples models of planetary interiors, atmospheres, chemistry, and orbital dynamics to simulate how rocky planets evolve from molten beginnings to potentially habitable worlds.
    </p>

    <h5 class="section-label">Modules</h5>
    <div class="overview-modules">
      {overviewModules.map((m) => (
        <div class="overview-module">
          <span class={`module-swatch swatch-${m.domain}`}></span>
          <div>
            <strong>{m.name}</strong>
            <span class="module-brief">{m.brief}</span>
          </div>
        </div>
      ))}
    </div>
    <div class="overview-more">
      <a href="/modules" class="overview-link">Full module details</a>
    </div>
  </section>

<style is:global>
  /* ---------- hero ---------- */
  .hero {
    position: relative;
    overflow: hidden;
    background: var(--pt-grad-hero);
    border-bottom: 1px solid var(--pt-line-d);
  }
  .hero-inner {
    position: relative;
    z-index: 1;
    padding-top: 110px;
    padding-bottom: 96px;
  }
  .hero-glyph {
    position: absolute;
    right: -14vmin;
    bottom: -22vmin;
    width: 58vmin;
    opacity: 0.16;
    pointer-events: none;
  }
  .hero-lockup { display: inline-flex; flex-direction: column; }
  .hero-lockup .word {
    display: inline-flex;
    align-items: center;
    font-family: var(--pt-font-display);
    font-weight: 800;
    font-size: clamp(56px, 10vw, 120px);
    letter-spacing: 0.01em;
    line-height: 1;
    color: var(--pt-paper);
  }
  .hero-lockup .word img {
    height: 1.06em;
    width: auto;
    margin: 0 0.015em 0 0.03em;
    transform: translateY(0.011em);
  }
  .hero-lockup .tag {
    font-family: var(--pt-font-mono);
    font-weight: 500;
    font-size: clamp(10px, 1.6vw, 20px);
    letter-spacing: var(--pt-track-tag);
    color: var(--pt-azure);
    align-self: flex-end;
    margin-top: 14px;
  }
  .hero-tagline {
    font-size: clamp(19px, 2.4vw, 26px);
    font-weight: 600;
    line-height: 1.45;
    color: var(--pt-text-d);
    max-width: 34ch;
    margin-top: 56px;
  }
  .hero-subtitle {
    font-size: 17px;
    line-height: 1.65;
    color: var(--pt-text-d2);
    max-width: 62ch;
    margin-top: 18px;
  }
  .hero-actions { display: flex; flex-wrap: wrap; gap: 14px; margin-top: 40px; }
  .hero-band {
    position: relative;
    z-index: 1;
    height: 8px;
    background: var(--pt-grad-phase);
  }

  /* ---------- overview ---------- */
  .home-overview { padding: 72px 0 0; }
  .overview-lead {
    font-size: 19px;
    line-height: 1.7;
    color: var(--pt-text-d2);
    max-width: 76ch;
  }
  .home-overview .section-label { margin-top: 64px; }
  .overview-modules {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 14px 48px;
  }
  .overview-module {
    display: flex;
    align-items: flex-start;
    gap: 14px;
    padding: 6px 0;
  }
  .module-swatch {
    width: 22px;
    height: 14px;
    border-radius: 3px;
    flex-shrink: 0;
    margin-top: 5px;
  }
  .swatch-interior { background: var(--pt-dom-interior); }
  .swatch-outgassing { background: var(--pt-dom-outgassing); }
  .swatch-tidal { background: var(--pt-dom-tidal); }
  .swatch-chem { background: var(--pt-dom-chem); }
  .swatch-atmos { background: var(--pt-dom-atmos); }
  .swatch-stellar { background: var(--pt-dom-stellar); }
  .overview-module strong { color: var(--pt-text-d); font-size: 16px; }
  .module-brief {
    display: block;
    color: var(--pt-text-d3);
    font-size: 14.5px;
    margin-top: 2px;
  }
  .overview-more { margin-top: 20px; text-align: right; }
  .overview-link {
    font-family: var(--pt-font-mono);
    font-size: 13px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  @media (max-width: 576px) {
    .overview-modules { grid-template-columns: 1fr; }
    .overview-lead { font-size: 17px; }
    .hero-actions .btn { width: 100%; justify-content: center; }
  }
</style>
</Base>
